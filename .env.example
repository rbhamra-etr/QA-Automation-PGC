# -----------------------------------------------------------------------------
# How to use
# -----------------------------------------------------------------------------
# Copy this file to .env.qa or .env.uat and replace dummy values.
#
#   copy .env.example .env.qa
#   copy .env.example .env.uat
#
# Credential key convention:
#   {APP}_{ROLE}_USERNAME / {APP}_{ROLE}_PASSWORD
# Role names are uppercased with spaces replaced by _
#   "Dig Sup Mgr" -> DIG_SUP_MGR
# Single-user apps omit the role suffix:
#   {APP}_USERNAME / {APP}_PASSWORD

# -----------------------------------------------------------------------------
# Runtime and browser
# -----------------------------------------------------------------------------
ENV=qa
CI=false
HEADLESS=false
SLOW_MO=0

# Timeout/retry config used by core/configs/env.config.ts
DEFAULT_TIMEOUT=30000
DEFAULT_TIMEOUT_MS=30000
DEFAULT_RETRY_COUNT=3
IADAPTIVE_TIMEOUT_MS=30000
IADAPTIVE_RETRY_COUNT=3
SFDC_TIMEOUT_MS=30000
SFDC_RETRY_COUNT=3

# Optional: pin Chrome channel/binary
BROWSER_CHANNEL=chrome
BROWSER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# -----------------------------------------------------------------------------
# iAdaptive login gateway and app tile mapping
# -----------------------------------------------------------------------------
IADAPTIVE_ACCESS_URL=https://iadaptive-qa.example.com/userportal/identity/MyApps

# Backward-compatible alias used by getIAdaptiveUrl()
IADAPTIVE_URL=https://iadaptive-qa.example.com

# Optional tile label overrides per environment
SFDC_LINK_TEXT=Salesforce
SAP_LINK_TEXT=SAP
FIORI_LINK_TEXT=SAP NetWeaver Fiori DEV
APPIAN_LINK_TEXT=Appian

# Optional fallback URL if SFDC tile cannot be found
SFDC_RUN_URL=https://sfdc-qa.example.com/lightning
SFDC_ENV=SFDC_QA2

# -----------------------------------------------------------------------------
# App credentials (dummy examples)
# -----------------------------------------------------------------------------
# SFDC role-based users
SFDC_CSR_USERNAME=sfdc.csr@example.com
SFDC_CSR_PASSWORD=ChangeMe_SFDC_CSR
SFDC_OTP_USERNAME=sfdc.otp@example.com
SFDC_OTP_PASSWORD=ChangeMe_SFDC_OTP
SFDC_DIG_SUP_MGR_USERNAME=sfdc.digsupmgr@example.com
SFDC_DIG_SUP_MGR_PASSWORD=ChangeMe_SFDC_DIG_SUP_MGR
SFDC_HR_USERNAME=sfdc.hr@example.com
SFDC_HR_PASSWORD=ChangeMe_SFDC_HR
SFDC_FINANCIAL_ANALYST_USERNAME=sfdc.financial.analyst@example.com
SFDC_FINANCIAL_ANALYST_PASSWORD=ChangeMe_SFDC_FIN

# SAP role-based users
SAP_CSR_USERNAME=sap.csr@example.com
SAP_CSR_PASSWORD=ChangeMe_SAP_CSR
SAP_DIG_SUP_MGR_USERNAME=sap.digsupmgr@example.com
SAP_DIG_SUP_MGR_PASSWORD=ChangeMe_SAP_DIG_SUP_MGR

# Fiori role-based users (if used by feature steps)
FIORI_CSR_USERNAME=fiori.csr@example.com
FIORI_CSR_PASSWORD=ChangeMe_FIORI_CSR

# Appian shared user
APPIAN_USERNAME=appian.user@example.com
APPIAN_PASSWORD=ChangeMe_APPIAN

# Web role-based users (for steps like: I am logged into "Web" as "<Role>")
WEB_CUSTOMER_USERNAME=web.customer@example.com
WEB_CUSTOMER_PASSWORD=ChangeMe_WEB_CUSTOMER
WEB_AGENT_USERNAME=web.agent@example.com
WEB_AGENT_PASSWORD=ChangeMe_WEB_AGENT

# Legacy direct web credentials (optional)
WEB_USERNAME=web.user@example.com
WEB_PASSWORD=ChangeMe_WEB_USER

# Shared password mode used by step: sign in to 407ETR using user ID
WEB_SHARED_PASSWORD=ChangeMe_WEB_SHARED

# -----------------------------------------------------------------------------
# Web app navigation and selector overrides
# -----------------------------------------------------------------------------
WEB_BASE_URL=https://www.qat.example.com
WEB_HOME_PAGE_URL=/en/home
WEB_HOME_URL_CONTAINS=/myaccount/
WEB_LOGIN_URL_CONTAINS=/auth/login

# Optional delay tuning (milliseconds)
WEB_PRE_LOGIN_DELAY_MS=1200
WEB_PASSWORD_STEP_DELAY_MS=700
WEB_PASSWORD_TYPE_DELAY_MS=80
WEB_BEFORE_LOGIN_CLICK_DELAY_MS=500

# Optional selector overrides for unstable UI
WEB_COOKIE_OK_SELECTOR=
WEB_OUTAGE_CLOSE_SELECTOR=
WEB_MY_ACCOUNT_SELECTOR=
WEB_ACCOUNT_LOGIN_SELECTOR=
WEB_USERNAME_NEXT_SELECTOR=
WEB_HOME_MARKER_SELECTOR=
WEB_LOGIN_ERROR_SELECTOR=

# -----------------------------------------------------------------------------
# API services
# -----------------------------------------------------------------------------
TOLL_API_BASE_URL=https://api-qa.example.com/toll

# -----------------------------------------------------------------------------
# Jira integration (optional)
# -----------------------------------------------------------------------------
# JIRA_API_TOKEN should be generated for your own Atlassian account
# (or for a dedicated shared automation account managed by the team).
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=test.user@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=QA

# -----------------------------------------------------------------------------
# Xray integration (optional)
# -----------------------------------------------------------------------------
# Upload script defaults:
# - CUCUMBER_JSON_PATH defaults to reports/cucumber/cucumber-report.json
# - XRAY_MODE defaults to cloud
CUCUMBER_JSON_PATH=reports/cucumber/cucumber-report.json
XRAY_MODE=cloud

# Cloud mode
# XRAY_CLIENT_ID and XRAY_CLIENT_SECRET are issued by Xray app registration
# and should match the team/project environment you are running against.
XRAY_BASE_URL=https://xray.cloud.getxray.app
XRAY_CLIENT_ID=your_xray_client_id
XRAY_CLIENT_SECRET=your_xray_client_secret
XRAY_PROJECT_KEY=QA
XRAY_TEST_EXECUTION_KEY=
XRAY_TEST_PLAN_KEY=

# Server/DC mode
XRAY_AUTH_TOKEN=your_xray_bearer_token


