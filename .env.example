# ── How to use ────────────────────────────────────────────────────────────────
# Copy this file to .env.qa or .env.uat and fill in the values for that environment.
#
#   copy .env.example .env.qa    # then fill in QA values
#   copy .env.example .env.uat   # then fill in UAT values
#
# Key convention: {APP}_{ROLE}_USERNAME / {APP}_{ROLE}_PASSWORD
# Role names are uppercased with spaces replaced by _  e.g. "Dig Sup Mgr" → DIG_SUP_MGR
# Single-user apps (Appian) omit the role: {APP}_USERNAME / {APP}_PASSWORD

# ── Browser settings ──────────────────────────────────────────────────────────
HEADLESS=false
SLOW_MO=0
DEFAULT_TIMEOUT=30000
# Optional: pin to a specific Chrome channel or binary
BROWSER_CHANNEL=
BROWSER_EXECUTABLE_PATH=

# ── IAdaptive portal (shared login gateway) ───────────────────────────────────
# IAdaptive + SFDC launch selection
IADAPTIVE_ACCESS_URL=https://aba0200.cyberark.cloud/userportal/identity/MyApps/VHJlZVRhYjphbGw%3D
# Optional: override the tile label shown in IAdaptive per environment
# SFDC_LINK_TEXT=SFDC_QAN1
# SAP_LINK_TEXT=SAP
# FIORI_LINK_TEXT=SAP NetWeaver Fiori DEV
# APPIAN_LINK_TEXT=Appian

